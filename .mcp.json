{
  "mcpServers": {
    "threejs-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "threejs-devtools-mcp"
      ],
      "env": {}
    },
    "mcp-three": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "mcp-three"
      ],
      "env": {}
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest"
      ],
      "env": {}
    }
  }
}